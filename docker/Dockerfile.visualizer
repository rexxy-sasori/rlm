FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY visualizer/package.json visualizer/package-lock.json ./

# Install dependencies
RUN npm ci

# Copy visualizer source code
COPY visualizer/ .

# Build the Next.js app
RUN npm run build

# Expose port 3000
EXPOSE 3000

# Start the production server
CMD ["npm", "start"]
